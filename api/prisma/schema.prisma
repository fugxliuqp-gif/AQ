generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformModule {
  id                BigInt   @id @default(autoincrement())
  moduleCode        String   @unique @map("module_code") @db.VarChar(64)
  moduleName        String   @map("module_name") @db.VarChar(128)
  moduleCategory    String?  @map("module_category") @db.VarChar(64)
  description       String?  @db.Text
  icon              String?  @db.VarChar(128)
  defaultPrice      Decimal? @map("default_price") @db.Decimal(10, 2)
  dependsOn         String[] @default([]) @map("depends_on")
  status            String   @default("active") @db.VarChar(16)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  licenses          TenantModuleLicense[]
  rolePermissions   RolePermission[]

  @@map("platform_modules")
}

model Tenant {
  id                BigInt   @id @default(autoincrement())
  tenantCode        String   @unique @map("tenant_code") @db.VarChar(64)
  tenantName        String   @map("tenant_name") @db.VarChar(128)
  tenantType        String?  @map("tenant_type") @db.VarChar(32)
  status            String   @default("active") @db.VarChar(16)
  subscriptionPlan  String?  @map("subscription_plan") @db.VarChar(32)
  startDate         DateTime? @map("start_date") @db.Date
  expireDate        DateTime? @map("expire_date") @db.Date
  maxUsers          Int      @default(10) @map("max_users")
  maxStorageGb      Int      @default(50) @map("max_storage_gb")
  contactName       String?  @map("contact_name") @db.VarChar(64)
  contactPhone      String?  @map("contact_phone") @db.VarChar(32)
  contactEmail      String?  @map("contact_email") @db.VarChar(128)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         BigInt?  @map("created_by")

  users             User[]
  licenses          TenantModuleLicense[]
  loginLogs         LoginLog[]
  roles             Role[]

  @@index([status])
  @@index([expireDate])
  @@map("tenants")
}

model TenantModuleLicense {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  moduleCode    String    @map("module_code") @db.VarChar(64)
  status        String    @default("active") @db.VarChar(16)
  startDate     DateTime? @map("start_date") @db.Date
  expireDate    DateTime? @map("expire_date") @db.Date
  maxUsers      Int?      @map("max_users")
  customPrice   Decimal?  @map("custom_price") @db.Decimal(10, 2)
  configJson    Json?     @default("{}") @map("config_json")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module        PlatformModule @relation(fields: [moduleCode], references: [moduleCode])

  @@unique([tenantId, moduleCode])
  @@index([tenantId])
  @@index([expireDate])
  @@map("tenant_module_licenses")
}

model Role {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  roleName      String    @map("role_name") @db.VarChar(64)
  description   String?   @db.Text
  isDefault     Boolean   @default(false) @map("is_default")
  status        String    @default("active") @db.VarChar(16)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     BigInt?   @map("created_by")

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions   RolePermission[]
  userRoles     UserRole[]

  @@unique([tenantId, roleName])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  id            BigInt    @id @default(autoincrement())
  roleId        BigInt    @map("role_id")
  moduleCode    String    @map("module_code") @db.VarChar(64)
  actions       String[]  @default([]) // e.g. read, write, delete, execute
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module        PlatformModule @relation(fields: [moduleCode], references: [moduleCode])

  @@unique([roleId, moduleCode])
  @@index([roleId])
  @@map("role_permissions")
}

model User {
  id              BigInt    @id @default(autoincrement())
  tenantId        BigInt?   @map("tenant_id")
  username        String    @db.VarChar(64)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  realName        String?   @map("real_name") @db.VarChar(64)
  phone           String?   @db.VarChar(32)
  email           String?   @db.VarChar(128)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(255)
  role            String    @db.VarChar(32) // system-level default role: super_admin/tenant_admin/tenant_user/auditor
  status          String    @default("active") @db.VarChar(16)
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp     String?   @map("last_login_ip") @db.Inet
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       BigInt?   @map("created_by")

  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modulePerms     UserModulePermission[]
  dataScopes      UserDataScope[]
  loginLogs       LoginLog[]
  operationLogs   OperationLog[]
  userRoles       UserRole[]

  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([role])
  @@index([status])
  @@map("users")
}

model UserRole {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  roleId      BigInt    @map("role_id")
  assignedBy  BigInt?   @map("assigned_by")
  assignedAt  DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model UserModulePermission {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  moduleCode  String    @map("module_code") @db.VarChar(64)
  status      String    @default("granted") @db.VarChar(16)
  grantedBy   BigInt?   @map("granted_by")
  grantedAt   DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleCode])
  @@map("user_module_permissions")
}

model UserDataScope {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  scopeType   String    @map("scope_type") @db.VarChar(32)
  scopeId     BigInt    @map("scope_id")
  scopeName   String?   @map("scope_name") @db.VarChar(64)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_data_scopes")
}

model LoginLog {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt?   @map("user_id")
  tenantId      BigInt?   @map("tenant_id")
  username      String?   @db.VarChar(64)
  loginType     String?   @map("login_type") @db.VarChar(16)
  ipAddress     String?   @map("ip_address") @db.Inet
  userAgent     String?   @map("user_agent") @db.Text
  status        String?   @db.VarChar(16)
  failReason    String?   @map("fail_reason") @db.VarChar(128)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])

  @@map("login_logs")
}

model OperationLog {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt?   @map("user_id")
  tenantId      BigInt?   @map("tenant_id")
  action        String    @db.VarChar(64)
  resourceType  String?   @map("resource_type") @db.VarChar(64)
  resourceId    BigInt?   @map("resource_id")
  beforeData    Json?     @map("before_data")
  afterData     Json?     @map("after_data")
  ipAddress     String?   @map("ip_address") @db.Inet
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User?     @relation(fields: [userId], references: [id])

  @@map("operation_logs")
}
